# =========================================================
# COPY THIS FILE, RENAME THE COPY TO ".env", THEN FILL IN
# YOUR REAL VALUES BELOW. NEVER SHARE OR UPLOAD YOUR .env FILE.
# =========================================================

# The Gmail address the server will send FROM
GMAIL_USER=youraddress@gmail.com

# The 16-character App Password you generate from Google
# (NOT your normal Gmail password — see SETUP-INSTRUCTIONS.txt)
GMAIL_APP_PASSWORD=your16charapppassword

# Where enquiries should be delivered TO (can be same as GMAIL_USER)
CONTACT_RECEIVER_EMAIL=info@manstallimited.com

# Port the server runs on locally — 3000 is fine, no need to change
PORT=3000
